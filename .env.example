# 测试网部署者私钥(0x 开头,需先领测试网 BNB:https://www.bnbchain.org/en/testnet-faucet)
PRIVATE_KEY=0xyour_testnet_deployer_private_key

# 可选:自定义 treasury 地址。测试网不填则默认 = 部署者地址。
# 主网务必填 Gnosis Safe 多签地址。
TREASURY_ADDRESS=

# 可选:自定义 BSC 测试网 RPC(不填用默认公共节点)
BSC_TESTNET_RPC=

# BscScan API key(用于源码验证;Etherscan v2 单一 key 可多链)
BSCSCAN_API_KEY=
